# ════════════════════════════════════════════════════════════
# Kuwait Events Platform — Environment Variables (Railway)
# Copy this file to .env locally, or set these in Railway Variables tab
# ════════════════════════════════════════════════════════════

# ─── Database (Supabase PostgreSQL) ───
# Get this from: Supabase → Project Settings → Database → Connection string → URI
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"
# Direct connection (for migrations — bypasses PgBouncer pooling):
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"

# ─── Authentication (Clerk) ───
# Get these from: Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
# Get this from: Clerk Dashboard → Webhooks → Create Endpoint (Endpoint secret)
CLERK_WEBHOOK_SECRET="whsec_..."
# Clerk redirect URLs — replace YOUR_RAILWAY_DOMAIN with your Railway app URL
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/login"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/register"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/"

# ─── JWT Secret (for custom auth fallback) ───
# Generate with: openssl rand -base64 48  (must be at least 32 chars)
JWT_SECRET="generate-a-random-secret-at-least-32-chars-long"

# ─── KNet Payment Gateway ───
# Use test credentials during development; switch to production when live
KNET_MERCHANT_ID="your-merchant-id"
KNET_TERMINAL_ID="your-terminal-id"
KNET_SECRET_KEY="your-secret-key"
KNET_RESOURCE_KEY="your-resource-key"
KNET_BASE_URL="https://kpaytest.com.kw"
# Replace YOUR_RAILWAY_DOMAIN with your Railway app URL
KNET_CALLBACK_URL="https://YOUR_RAILWAY_DOMAIN.up.railway.app/api/v1/payments/callback"

# ─── Cloudflare R2 Storage (image uploads) ───
# Get these from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key"
R2_SECRET_ACCESS_KEY="your-secret-key"
R2_BUCKET_NAME="your-bucket"
R2_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
R2_PUBLIC_URL="https://your-bucket.r2.dev"

# ─── Email (Resend) ───
# Get this from: Resend Dashboard → API Keys
RESEND_API_KEY="re_..."
EMAIL_FROM="no-reply@kuwaitevents.com"

# ─── Rate Limiting (Upstash Redis) ───
# Get these from: Upstash Console → your database → REST API
# Optional — the app falls back to in-memory rate limiting if these are missing
UPSTASH_REDIS_REST_URL="https://your-endpoint.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# ─── App Configuration ───
# Replace YOUR_RAILWAY_DOMAIN with your Railway app URL after first deploy
NEXT_PUBLIC_APP_URL="https://YOUR_RAILWAY_DOMAIN.up.railway.app"
NODE_ENV="production"
